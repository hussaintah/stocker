# Copy to .env and fill in your values
SECRET_KEY=your-secret-key-here

# AWS Credentials (use IAM role on EC2 — only needed for local dev)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# DynamoDB Table Names (defaults match setup_dynamodb.py)
DYNAMODB_TABLE_USERS=stocker_users
DYNAMODB_TABLE_PORTFOLIO=stocker_portfolio
DYNAMODB_TABLE_ORDERS=stocker_orders
DYNAMODB_TABLE_STOCKS=stocker_stocks
